@using eShopLegacy.Utilities
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Catalog manager (MVC)</title>
    <link rel="stylesheet" href="~/Content/bootstrap.css" />
    <link rel="stylesheet" href="~/Content/site.css" />
</head>
<body>
    <header class="navbar navbar-light navbar-static-top">
        <div class="esh-header-brand">
            <a asp-controller="Catalog" asp-action="Index">
                <img src="~/images/brand.png" />
            </a>
            <a class="btn esh-button esh-button-primary" asp-controller="AspNetSession" asp-action="Index">Session</a>
            <a class="btn esh-button esh-button-primary" asp-controller="UserInfo" asp-action="Index">User Info</a>
            <a class="btn esh-button esh-button-primary" asp-controller="Documents" asp-action="Index">Documents</a>
        </div>
        <div class="esh-header-brand-right">
            <partial name="_LoginPartial" />
        </div>
    </header>
    <section class="esh-app-hero">
        <div class="container esh-header">
            <h1 class="esh-header-title">Catalog manager <span>(MVC)</span></h1>
        </div>
    </section>

    @RenderBody()

    <footer class="esh-app-footer">
        <div class="container">
            <article class="row">
                <section class="col-sm-6">
                    <img class="esh-app-footer-brand" src="~/images/brand_dark.png" />
                </section>
                <section class="col-sm-6">
                    <img class="esh-app-footer-text hidden-xs" src="~/images/main_footer_text.png" width="335" height="26" alt="footer text image" />
                    <br />
                    @{ 
                        var sessionInfo = $"{HttpContextAccessor.HttpContext.Session.GetString("MachineName")}, {HttpContextAccessor.HttpContext.Session.GetString("SessionStartTime")}";
                    }
                    <small>@sessionInfo</small>
                    <br />
                    <small>@WebHelper.UserAgent</small>
                </section>
            </article>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
